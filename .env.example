# ===========================================
# Grove — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# The app runs in demo mode when Plaid keys are empty.

# ---------- Database ----------
# SQLite for local dev. Use a hosted DB (e.g. Turso, PlanetScale) for production.
DATABASE_URL="file:./dev.db"

# ---------- Plaid ----------
# Leave empty to run in demo mode (no bank connection required).
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
